{
  "manifest_version": 3,
  "name": "Font Switcher",
  "version": "1.0.0",
  "description": "Discover font combinations on a page and replace them per-site.",
  "permissions": ["storage", "contextMenus", "tabs"],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Open Font Switcher"
  },
  "options_ui": {
    "page": "src/ui/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
